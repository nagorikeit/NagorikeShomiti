# Treat all files as text by default, with automatic CRLF/LF handling
* text=auto

# Explicitly mark binary files to prevent Git from altering their line endings or contents.
# This prevents Gradle Wrapper JAR (gradle-wrapper.jar) or any library JARs from getting corrupted.
*.jar binary
*.aar binary
*.so binary
*.apk binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary

# Ensure shell scripts always use LF (Unix) line endings, even when checked out on Windows.
# This is crucial for execution permissions of ./gradlew on Linux/macOS environments (like GitHub Actions).
gradlew text eol=lf
*.sh text eol=lf

# Windows batch files should use CRLF line endings
*.bat text eol=crlf
*.cmd text eol=crlf
